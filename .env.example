# ── Copy this file to .env and fill in your own keys ──

# Cerebras API (get from https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# Semantic Scholar (optional — free tier works without)
SEMANTIC_SCHOLAR_API_KEY=

# Cache directory for retrieved papers
CACHE_DIR=data
